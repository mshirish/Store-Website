SECRET_KEY=replace-me-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://store_user:password@localhost:5432/store_db

# Email — leave unset to use the console backend in development
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Our Store <noreply@example.com>

# Stripe (test mode keys — get from https://dashboard.stripe.com/test/apikeys)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Get from `stripe listen` output (whsec_...) — see README for setup
STRIPE_WEBHOOK_SECRET=whsec_...
