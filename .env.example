SECRET_KEY=replace-me-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# Individual components — used by Docker Compose to build DATABASE_URL
# automatically with the correct internal hostname ('db'). Keep these in sync
# with the values in DATABASE_URL below.
DB_NAME=store_db
DB_USER=store_user
DB_PASSWORD=changeme
DB_PORT=5432

# Full connection URL for the Django app:
#   • Native Postgres (running Postgres directly on your machine):
DATABASE_URL=postgres://store_user:changeme@localhost:5432/store_db
#   • Docker Compose: you do NOT need to change this line.
#     docker-compose.yml overrides DATABASE_URL to use the 'db' service name
#     automatically, built from the DB_* variables above.

# ── Email ─────────────────────────────────────────────────────────────────────
# Leave EMAIL_HOST blank to print emails to the terminal (console backend).
# Fill in SMTP credentials to send real emails.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Our Store <noreply@example.com>

# ── Auth ──────────────────────────────────────────────────────────────────────
# 'none'      — skip email verification (fast dev testing, no SMTP needed)
# 'mandatory' — require email verification before login (use in production)
ACCOUNT_EMAIL_VERIFICATION=none

# ── Stripe (test mode) ────────────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Get from `stripe listen` output (whsec_...) — see README for setup
STRIPE_WEBHOOK_SECRET=whsec_...
